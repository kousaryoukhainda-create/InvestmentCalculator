<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Currency Selector Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_currency"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerCurrency"
                    android:layout_width="140dp"
                    android:layout_height="40dp"
                    android:background="@drawable/currency_spinner_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/inputCard"
                style="@style/InputCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Principal Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPrincipal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_principal"
                        android:layout_marginBottom="12dp"
                        app:startIconDrawable="@drawable/ic_currency"
                        app:startIconTint="@color/primary"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:errorIconDrawable="@drawable/ic_error"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPrincipal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Annual Rate Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_rate"
                        android:layout_marginBottom="8dp"
                        app:startIconDrawable="@drawable/ic_percent"
                        app:startIconTint="@color/primary"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Quick Rate Presets -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_preset_rates"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupRates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="false"
                        app:chipSpacingHorizontal="6dp"
                        app:chipSpacingVertical="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip6pct"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_6pct"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip8pct"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_8pct"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip10pct"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_10pct"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip12pct"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_12pct"
                            android:checkable="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip15pct"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_15pct"
                            android:checkable="true" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Time Period Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_time"
                        android:layout_marginBottom="12dp"
                        app:startIconDrawable="@drawable/ic_time"
                        app:startIconTint="@color/primary"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Compound Frequency -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_frequency"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="@color/input_background"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="1dp">

                        <Spinner
                            android:id="@+id/spinnerCompoundFrequency"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:background="@android:color/transparent" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Monthly SIP Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMonthlySIP"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_monthly_sip"
                        app:startIconDrawable="@drawable/ic_currency"
                        app:startIconTint="@color/primary"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMonthlySIP"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons - Compact Grid Layout -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnCalculateCompound"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/btn_compound_short"
                    style="@style/PrimaryButton"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_calculate"
                    app:iconGravity="textStart"
                    app:iconSize="18dp" />

                <Button
                    android:id="@+id/btnCalculateSimple"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/btn_simple_short"
                    style="@style/SecondaryButton"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_calculate"
                    app:iconGravity="textStart"
                    app:iconSize="18dp" />

                <Button
                    android:id="@+id/btnCalculateSIP"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/btn_sip_short"
                    style="@style/SecondaryButton"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_sip"
                    app:iconGravity="textStart"
                    app:iconSize="18dp" />

                <Button
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/btn_clear"
                    style="@style/OutlinedButton"
                    android:textSize="12sp" />

            </GridLayout>

            <!-- Result Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultCard"
                style="@style/ResultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/gradient_start">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvCalculationType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Calculation Result"
                        android:textSize="14sp"
                        android:textColor="@color/text_on_dark"
                        android:alpha="0.9"
                        android:layout_marginBottom="12dp" />

                    <!-- Future Value - Main Result -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_future_value"
                            style="@style/ResultTitleText"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvFutureValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            style="@style/ResultValueText" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/text_on_dark"
                        android:alpha="0.2"
                        android:layout_marginBottom="16dp" />

                    <!-- Details Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3">

                        <!-- Principal -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_principal_invested"
                                style="@style/ResultTitleText"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvPrincipal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                style="@style/ResultSubValueText" />

                        </LinearLayout>

                        <!-- Total Interest -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_interest_earned"
                                style="@style/ResultTitleText"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvTotalInterest"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                style="@style/ResultSubValueText" />

                        </LinearLayout>

                        <!-- Rate -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_rate_short"
                                style="@style/ResultTitleText"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                style="@style/ResultSubValueText" />

                        </LinearLayout>

                        <!-- Time -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_time_short"
                                style="@style/ResultTitleText"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 yrs"
                                style="@style/ResultSubValueText" />

                        </LinearLayout>

                    </GridLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Growth Chart Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chartCard"
                style="@style/InputCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_growth_chart"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/growthChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="20dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
